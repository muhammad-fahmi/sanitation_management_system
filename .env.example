# ── Docker environment overrides ─────────────────────────────────────────────
# Copy this file to .env and adjust values before running docker compose.

# Docker image name and tag (used when building/pushing)
DOCKER_IMAGE=your-dockerhub-username/bionic-backend
DOCKER_TAG=latest

# Host port the app will be accessible on
APP_PORT=8080

# Application
CI_ENVIRONMENT=production
APP_BASE_URL=http://localhost:8080/

# Database
DB_NAME=bionic_db
DB_USER=bionic_user
DB_PASS=change_me_in_production

# Cache (Redis)
CACHE_HANDLER=redis
CACHE_BACKUP_HANDLER=file
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Boot seeding
AUTO_SEED=true
SEED_FORCE=false
SEEDER_CLASS=MainSeeder
