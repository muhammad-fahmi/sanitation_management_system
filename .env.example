
# Docker image name and tag (used when building/pushing)
DOCKER_IMAGE=<your_docker_image_name>
DOCKER_TAG=latest

# Host port the app will be accessible on
APP_PORT=<your_app_port>

# Application
CI_ENVIRONMENT=production
APP_BASE_URL=http://localhost:<your_app_port>/
COOKIE_DOMAIN=

# Database
DB_NAME=bionic_db
DB_USER=<your_db_user>
DB_PASS=<your_db_password>

# Cache (Redis)
CACHE_HANDLER=redis
CACHE_BACKUP_HANDLER=file
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Boot seeding
AUTO_SEED=true
SEED_FORCE=false
SEEDER_CLASS=MainSeeder
